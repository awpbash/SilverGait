# ==============================================
# SilverPhysio Environment Configuration
# ==============================================
# Copy this file to .env and fill in your API keys

# REQUIRED: Google Gemini API Key
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OPTIONAL: Health Promotion Board (HPB) Wearables API
# Used for real activity tracking data from wearables
# App works in demo mode without this
HPB_API_KEY=

# OPTIONAL: SEA-LION API Key
# Used for Singlish translation features
# App works without this
SEALION_API_KEY=
